# Database
POSTGRES_USER=dbank_admin
POSTGRES_PASSWORD=secure_admin_password_here
POSTGRES_DB=dbank_analytics
POSTGRES_HOST=db
POSTGRES_PORT=5432

# Data Transformation User (has access to raw and can write to marts)
DBT_USER=dbank_dbt
DBT_PASSWORD=secure_dbt_password_here

# Read-Only App User (strict least privilege, ONLY has access to marts)
APP_USER=dbank_app
APP_PASSWORD=secure_app_password_here

# API
API_PORT=8000

# LLM
GOOGLE_API_KEY=your_google_api_key_here